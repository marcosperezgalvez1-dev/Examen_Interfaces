        }

        footer {
            text-align: center;
            padding: 2rem 0;
            color: #6f7c91;
            font-size: 0.8rem;
            font-family: 'JetBrains Mono', monospace;
            border-top: 1px solid #1e222b;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .navbar {
                flex-direction: row;
            }
            .nav-links {
                display: none;
                width: 100%;
                flex-direction: column;
                gap: 1rem;
                padding: 1.2rem 0;
                text-align: center;
                background: #0f1117;
                border-radius: 1rem;
                margin-top: 1rem;
                border: 1px solid #2a2f3a;
            }
            .nav-links.show {
                display: flex;
            }
            .menu-toggle {
                display: block;
            }
            .hero h1 {
                font-size: 1.9rem;
            }
            .section-title {
                font-size: 1.6rem;
            }
        }
        html {
            scroll-padding-top: 80px;
        }
        ::selection {
            background: #5a7bbf;
            color: #0a0c10;
        }
    </style>
</head>
