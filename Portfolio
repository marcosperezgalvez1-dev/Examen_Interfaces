        input:focus, textarea:focus {
            outline: none;
            border-color: #5a7bbf;
            box-shadow: 0 0 0 2px rgba(90,123,191,0.3);
        }

        button[type="submit"] {
            background: #1f2a3e;
            border: 1px solid #5a7bbf;
            color: white;
            padding: 0.8rem 1.8rem;
            border-radius: 40px;
            font-weight: 600;
