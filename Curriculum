<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Currículum</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f4f4f4;
        }

        .container {
            max-width: 900px;
            margin: 20px auto;
            background-color: white;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            display: grid;
            grid-template-columns: 280px 1fr;
        }

        /* Barra lateral de la izquierda */
        .sidebar {
            background-color: #2c3e50;
            color: white;
            padding: 25px 20px;
        }

        .profile-img {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: block;
            border: 3px solid white;
            object-fit: cover;
        }

        .sidebar h2 {
            border-bottom: 2px solid #3498db;
            padding-bottom: 8px;
            margin: 20px 0 15px;
            font-size: 1.2em;
            letter-spacing: 1px;
        }

        .sidebar h3 {
            margin: 15px 0 5px;
            color: #3498db;
            font-size: 1em;
        }

        .contact-info {
            list-style: none;
        }

        .contact-info li {
            margin-bottom: 12px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.9em;
            word-break: break-word;
        }

        .contact-info i {
            width: 20px;
            color: #3498db;
            flex-shrink: 0;
        }

        .contact-info span {
            line-height: 1.4;
        }

        .skills {
            list-style: none;
        }

        .skill-item {
            margin-bottom: 15px;
        }

        .skill-item span {
            display: block;
            margin-bottom: 5px;
            font-size: 0.9em;
        }

        .skill-bar {
            height: 6px;
            background-color: #34495e;
            border-radius: 3px;
            margin-top: 3px;
        }

        .skill-level {
            height: 100%;
            background-color: #3498db;
            border-radius: 3px;
        }

        .certifications-list {
            list-style: none;
        }

        .certifications-list li {
            margin-bottom: 12px;
            padding-left: 20px;
            position: relative;
            font-size: 0.9em;
            line-height: 1.4;
        }

        .certifications-list li:before {
            content: "▹";
            color: #3498db;
            position: absolute;
            left: 0;
        }

        /* Contenido principal */
        .main-content {
            padding: 30px 25px;
        }

        .header {
            margin-bottom: 25px;
        }

        .header h1 {
            font-size: 2.2em;
            color: #2c3e50;
            margin-bottom: 8px;
            line-height: 1.2;
        }

        .header .title {
            font-size: 1.1em;
            color: #3498db;
            margin-bottom: 15px;
            font-weight: 500;
        }

        .header .summary {
            color: #555;
            font-size: 0.95em;
            line-height: 1.6;
            text-align: justify;
        }

        .section {
            margin-bottom: 30px;
        }

        .section h2 {
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 6px;
            margin-bottom: 18px;
            font-size: 1.3em;
            letter-spacing: 0.5px;
        }

        .job, .education-item {
            margin-bottom: 22px;
        }

        .job-header, .edu-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 6px;
            gap: 8px;
        }

        .job-header h3, .edu-header h3 {
            color: #2c3e50;
            font-size: 1.1em;
            line-height: 1.3;
            flex: 1;
            min-width: 200px;
        }

        .company, .institution {
            color: #3498db;
            font-weight: 600;
            font-size: 0.95em;
            margin-bottom: 8px;
        }

        .date {
            color: #666;
            font-size: 0.85em;
            font-weight: 500;
            background: #f0f0f0;
            padding: 3px 8px;
            border-radius: 15px;
            white-space: nowrap;
        }

        .job-description {
            list-style: none;
            margin-top: 8px;
        }

        .job-description li {
            margin-bottom: 8px;
            padding-left: 20px;
            position: relative;
            font-size: 0.95em;
            line-height: 1.5;
            color: #444;
        }

        .job-description li:before {
            content: "•";
            color: #3498db;
            font-weight: bold;
            position: absolute;
            left: 5px;
        }

        /* Para textos muy largos en títulos */
        .job-header h3, .edu-header h3 {
            word-break: break-word;
            hyphens: auto;
        }

        /* Mejora para el enlace de GitHub */
        .contact-info a {
            color: white;
            text-decoration: none;
            word-break: break-all;
        }

        .contact-info a:hover {
            text-decoration: underline;
            color: #3498db;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                grid-template-columns: 1fr;
                margin: 10px;
            }
            
            .job-header, .edu-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .date {
                align-self: flex-start;
            }
            
            .header h1 {
                font-size: 1.8em;
            }
        }

        @media (max-width: 480px) {
            .sidebar {
                padding: 20px 15px;
            }
            
            .main-content {
                padding: 20px 15px;
            }
            
            .job-header h3, .edu-header h3 {
                font-size: 1em;
            }
        }
    </style>
</head>
